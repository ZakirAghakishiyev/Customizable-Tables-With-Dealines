<UserControl x:Class="CustomizableTablesWithDeadlines.Views.DeadlinesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CustomizableTablesWithDeadlines.Converters"
             xmlns:loc="clr-namespace:CustomizableTablesWithDeadlines.Localization">
    <UserControl.Resources>
        <conv:DeadlineStatusToBrushConverter x:Key="StatusBrush" />
        <conv:FilterToTextConverter x:Key="FilterToText" />
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <ComboBox DockPanel.Dock="Right" ItemsSource="{Binding FilterOptions}"
                      SelectedItem="{Binding SelectedFilter}" Style="{StaticResource ModernComboBox}" MinWidth="180">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource FilterToText}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="{Binding Strings.Status}" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
            <DataGrid ItemsSource="{Binding Deadlines}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{loc:Loc Key=TableName}" />
                        </DataGridTextColumn.Header>
                        <DataGridTextColumn.Binding>
                            <Binding Path="TableName" />
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="*">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{loc:Loc Key=RowInfo}" />
                        </DataGridTextColumn.Header>
                        <DataGridTextColumn.Binding>
                            <Binding Path="RowInfo" />
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="*">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{loc:Loc Key=DeadlineTitle}" />
                        </DataGridTextColumn.Header>
                        <DataGridTextColumn.Binding>
                            <Binding Path="Title" />
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="*">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{loc:Loc Key=DeadlineDateTime}" />
                        </DataGridTextColumn.Header>
                        <DataGridTextColumn.Binding>
                            <Binding Path="DeadlineDateTimeText" />
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="120">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{loc:Loc Key=RemainingTime}" />
                        </DataGridTextColumn.Header>
                        <DataGridTextColumn.Binding>
                            <Binding Path="RemainingTimeText" />
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Width="120">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{loc:Loc Key=Status}" />
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,4" HorizontalAlignment="Left"
                                        Background="{Binding Status, Converter={StaticResource StatusBrush}}">
                                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="12" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
