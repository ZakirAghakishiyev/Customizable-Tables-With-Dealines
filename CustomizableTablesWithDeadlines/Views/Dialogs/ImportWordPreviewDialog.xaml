<Window x:Class="CustomizableTablesWithDeadlines.Views.Dialogs.ImportWordPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Strings.ImportFromWord}"
        Width="900" Height="620"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Strings.ImportWordPreviewDescription}" Style="{StaticResource MutedText}" Margin="0,0,0,12" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding Strings.SelectTableToImport}" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedTable}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding Strings.TablePreview}" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" />
                    <DataGrid ItemsSource="{Binding PreviewData}"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0" />
                </DockPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="{Binding Strings.TableName}" Style="{StaticResource MutedText}" />
            <TextBox Text="{Binding TableName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="{Binding Strings.SuggestedDeadlineColumns}" Style="{StaticResource SectionTitle}" Margin="0,0,0,4" />
                <TextBlock Text="{Binding Strings.SuggestedDeadlineColumnsHint}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding DeadlineSuggestions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding ColumnName}" IsChecked="{Binding IsSelected}" Margin="0,2,0,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding Strings.NoDeadlineColumnsDetected}"
                           Style="{StaticResource MutedText}"
                           Margin="0,4,0,0"
                           Visibility="{Binding DeadlineSuggestions.Count, Converter={StaticResource CountToVisibility}, ConverterParameter=Empty}" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{Binding Strings.Cancel}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="{Binding Strings.Import}" Style="{StaticResource PrimaryButton}" Click="Import_Click" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
