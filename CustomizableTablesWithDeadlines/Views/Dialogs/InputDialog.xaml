<Window x:Class="CustomizableTablesWithDeadlines.Views.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:CustomizableTablesWithDeadlines.Localization"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MinWidth="400"
        Background="{StaticResource BackgroundBrush}">
    <Border Style="{StaticResource CardBorder}" Margin="16">
        <StackPanel>
            <TextBlock x:Name="TitleText" Style="{StaticResource SectionTitle}" />
            <TextBlock x:Name="PromptText" Style="{StaticResource MutedText}" Margin="0,0,0,12" />
            <TextBox x:Name="InputTextBox" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{loc:Loc Key=Cancel}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="{loc:Loc Key=Save}" Style="{StaticResource PrimaryButton}" Click="Ok_Click" IsDefault="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
