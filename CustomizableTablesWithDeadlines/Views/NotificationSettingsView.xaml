<UserControl x:Class="CustomizableTablesWithDeadlines.Views.NotificationSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CustomizableTablesWithDeadlines.Converters">
    <UserControl.Resources>
        <conv:NotifyOptionToTextConverter x:Key="NotifyOptionToText" />
        <conv:EnumToVisibilityConverter x:Key="EnumToVisibility" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{StaticResource PagePadding}" MaxWidth="640">
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{Binding Strings.DefaultNotifyBefore}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                    <ComboBox ItemsSource="{Binding NotifyOptions}" SelectedItem="{Binding DefaultNotifyBefore}"
                              Style="{StaticResource ModernComboBox}" Margin="0,0,0,12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource NotifyOptionToText}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16"
                                Visibility="{Binding DefaultNotifyBefore, Converter={StaticResource EnumToVisibility}, ConverterParameter=Custom}">
                        <TextBlock Text="{Binding Strings.CustomMinutes}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Text="{Binding DefaultCustomNotifyMinutes}" Style="{StaticResource ModernTextBox}" Width="100" />
                    </StackPanel>

                    <CheckBox Content="{Binding Strings.EnableDesktopNotifications}" Style="{StaticResource ModernCheckBox}"
                              IsChecked="{Binding EnableDesktopNotifications}" />
                    <CheckBox Content="{Binding Strings.EnableSound}" Style="{StaticResource ModernCheckBox}"
                              IsChecked="{Binding EnableSound}" />
                    <CheckBox Content="{Binding Strings.StartWithWindows}" Style="{StaticResource ModernCheckBox}"
                              IsChecked="{Binding StartWithWindows}" />

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="{Binding Strings.Save}" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" Margin="0,0,8,0" />
                        <Button Content="{Binding Strings.TestNotification}" Style="{StaticResource SecondaryButton}"
                                Command="{Binding TestNotificationCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
