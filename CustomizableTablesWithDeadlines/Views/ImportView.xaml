<UserControl x:Class="CustomizableTablesWithDeadlines.Views.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="{Binding Strings.ImportFromWord}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                    Command="{Binding BrowseFileCommand}" />
            <Button Content="{Binding Strings.Import}" Style="{StaticResource SecondaryButton}"
                    Command="{Binding ImportSelectedTableCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="{Binding SelectedFilePath}" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
            <CheckBox Content="{Binding Strings.SelectTableToImport}" IsChecked="{Binding FirstRowAsHeader}" Margin="0,8,0,0" />
            <TextBox Text="{Binding TableName}" Style="{StaticResource ModernTextBox}" Margin="0,8,0,0" />
            <CheckBox Content="{Binding Strings.SuggestedDeadlineColumns}" IsChecked="{Binding CreateDeadlinesFromDateColumns}" Margin="0,8,0,0" />
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" Margin="0,8,0,0" />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <ListBox ItemsSource="{Binding DetectedTables}" SelectedItem="{Binding SelectedTable}" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="Table " />
                            <Run Text="{Binding TableIndex}" />
                            <Run Text=" (" />
                            <Run Text="{Binding RowCount}" />
                            <Run Text=" x " />
                            <Run Text="{Binding ColumnCount}" />
                            <Run Text=")" />
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
