<UserControl x:Class="CustomizableTablesWithDeadlines.Views.TableEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CustomizableTablesWithDeadlines.Converters">
    <UserControl.Resources>
        <conv:ColumnTypeToTextConverter x:Key="ColumnTypeToText" />
        <DataTemplate x:Key="RowActionsTemplate">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button Style="{StaticResource GridIconButton}"
                        Margin="0,0,6,0"
                        ToolTip="{Binding DataContext.Strings.ManageDeadlines, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        Command="{Binding DataContext.ManageDeadlinesCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding _RowId}">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE787;"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
                <Button Style="{StaticResource GridDangerIconButton}"
                        ToolTip="{Binding DataContext.Strings.DeleteRow, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        Command="{Binding DataContext.DeleteRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                        CommandParameter="{Binding _RowId}">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE74D;"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="{Binding Strings.BackToTables}" Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"
                    Command="{Binding BackToTablesCommand}" />
            <TextBox Text="{Binding TableName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"
                     MinWidth="280" FontSize="18" FontWeight="SemiBold" />
            <Button Content="{Binding Strings.Save}" Style="{StaticResource PrimaryButton}" Margin="12,0,0,0"
                    Command="{Binding SaveCommand}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <Expander IsExpanded="True" Background="Transparent" BorderThickness="0">
                <Expander.Header>
                    <TextBlock Text="{Binding Strings.Columns}" Style="{StaticResource SectionTitle}" Margin="0" />
                </Expander.Header>
                <StackPanel>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="{Binding Strings.AddColumn}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                    Command="{Binding AddColumnCommand}" />
                            <Button Content="{Binding Strings.RenameColumn}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                    Command="{Binding RenameColumnCommand}" />
                            <Button Content="{Binding Strings.DeleteColumn}" Style="{StaticResource DangerButton}" Margin="0,0,8,0"
                                    Command="{Binding DeleteColumnCommand}" />
                            <Button Content="{Binding Strings.MoveColumnLeft}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                                    Command="{Binding MoveColumnLeftCommand}" />
                            <Button Content="{Binding Strings.MoveColumnRight}" Style="{StaticResource SecondaryButton}" Margin="0,0,16,0"
                                    Command="{Binding MoveColumnRightCommand}" />
                            <TextBlock Text="{Binding Strings.ColumnType}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox ItemsSource="{Binding Source={x:Static conv:ColumnTypeValues.All}}"
                                      SelectedItem="{Binding SelectedColumnType}"
                                      Style="{StaticResource ModernComboBox}" Width="140" Margin="0,0,8,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource ColumnTypeToText}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Content="{Binding Strings.ApplyColumnType}" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ChangeColumnTypeCommand}" />
                        </StackPanel>
                    </ScrollViewer>
                    <ListBox ItemsSource="{Binding Columns}" SelectedItem="{Binding SelectedColumn}"
                             DisplayMemberPath="Name" MinHeight="60" MaxHeight="100"
                             HorizontalAlignment="Stretch" />
                </StackPanel>
            </Expander>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="{Binding Strings.AddRow}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                    Command="{Binding AddRowCommand}" />
        </StackPanel>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="0" HorizontalAlignment="Stretch">
            <DataGrid x:Name="DataGrid"
                      ItemsSource="{Binding GridData}"
                      HorizontalAlignment="Stretch"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      MinColumnWidth="100"
                      RowHeight="44"
                      ColumnWidth="*"
                      Margin="0" />
        </Border>
    </Grid>
</UserControl>
