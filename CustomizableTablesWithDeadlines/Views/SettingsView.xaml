<UserControl x:Class="CustomizableTablesWithDeadlines.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CustomizableTablesWithDeadlines.Converters">
    <UserControl.Resources>
        <conv:LanguageToTextConverter x:Key="LanguageToText" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{StaticResource PagePadding}" MaxWidth="720">
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Strings.General}" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="{Binding Strings.Language}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                    <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"
                              Style="{StaticResource ModernComboBox}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource LanguageToText}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Strings.Appearance}" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="{Binding Strings.Theme}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                    <TextBox Text="{Binding Strings.ThemePlaceholder, Mode=OneWay}" Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Strings.Data}" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="{Binding Strings.BackupExport}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                    <Button Content="{Binding Strings.BackupExportPlaceholder}" Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left" IsEnabled="False" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{Binding Strings.About}" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="{Binding Strings.AppTitle}" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding Strings.AboutDescription}" TextWrapping="Wrap" Style="{StaticResource BodyText}" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding Strings.Version}" Style="{StaticResource MutedText}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
