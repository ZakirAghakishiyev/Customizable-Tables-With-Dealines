<Window x:Class="CustomizableTablesWithDeadlines.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CustomizableTablesWithDeadlines.ViewModels"
        xmlns:views="clr-namespace:CustomizableTablesWithDeadlines.Views"
        xmlns:loc="clr-namespace:CustomizableTablesWithDeadlines.Localization"
        Title="{loc:Loc Key=AppTitle}"
        MinWidth="1100" MinHeight="700"
        Width="1280" Height="800"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TablesViewModel}">
            <views:TablesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TableEditorViewModel}">
            <views:TableEditorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DeadlinesViewModel}">
            <views:DeadlinesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NotificationSettingsViewModel}">
            <views:NotificationSettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ImportViewModel}">
            <views:ImportView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,24">
                    <TextBlock Text="{loc:Loc Key=AppTitle}" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" />
                    <TextBlock Text="{loc:Loc Key=WelcomeSubtitle}" Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>

                <ListBox ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="8,2" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="border" Background="Transparent"
                                                CornerRadius="{StaticResource ButtonCornerRadius}"
                                                Padding="16,12">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           Foreground="{StaticResource PrimaryBrush}" />
                                <TextBlock Text="{Binding Title}" FontSize="14" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,20">
                <TextBlock Text="{Binding PageTitle}" Style="{StaticResource PageTitle}" />
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
        </Grid>
    </Grid>
</Window>
