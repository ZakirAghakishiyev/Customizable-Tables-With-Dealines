<Application x:Class="CustomizableTablesWithDeadlines.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CustomizableTablesWithDeadlines.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Colors.xaml" />
                <ResourceDictionary Source="Styles/Controls.xaml" />
                <ResourceDictionary Source="Styles/DataGrid.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:DeadlineStatusToBrushConverter x:Key="StatusBrush" />
            <conv:DeadlineStatusToTextConverter x:Key="StatusToText" />
            <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
            <conv:EnumToVisibilityConverter x:Key="EnumToVisibility" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
